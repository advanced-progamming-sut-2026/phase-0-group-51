+            return null;
+        }
+        String copiedName = normalized.substring(prefix.length()).trim();
+        if (copiedName.isEmpty()) {
+            return null;
+        }
+        PlantData target = PlantRegistry.getByName(copiedName);
+        if (target == null || target.id() == IMITATER_ID) {
+            return null;
+        }
+        return target;
